{
    "name": "ridgeben/smart-chatbot",
    "description": "Reusable Laravel database-aware AI chatbot using Ollama.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "chatbot",
        "ai",
        "ollama",
        "database-chatbot"
    ],
    "autoload": {
        "psr-4": {
            "Ridgeben\\SmartChatbot\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ridgeben\\SmartChatbot\\SmartChatbotServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}